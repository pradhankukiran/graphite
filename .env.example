# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_SETTINGS_MODULE=config.settings.development

# PostgreSQL
POSTGRES_DB=graphite
POSTGRES_USER=graphite
POSTGRES_PASSWORD=graphite_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CHANNEL_LAYER_URL=redis://redis:6379/2

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphite_neo4j_dev
NEO4J_DATABASE=

# LLM Providers (configure at least one)
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Optional Vercel Blob uploads
VERCEL_BLOB_ENABLED=False
BLOB_READ_WRITE_TOKEN=
VERCEL_BLOB_ACCESS=public
VERCEL_BLOB_PATH_PREFIX=documents

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
